{
  "name": "decentralized_payrole-tests",
  "version": "1.0.0",
  "description": "Run unit tests on this project.",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:report": "vitest run -- --coverage --costs",
    "test:watch": "chokidar \"tests/**/*.ts\" \"contracts/**/*.clar\" -c \"npm run test:report\"",
    "deploy:testnet": "node scripts/deploy-testnet.js",
    "deploy:devnet": "clarinet deployments generate --devnet && clarinet deployments apply",
    "deploy:mainnet": "clarinet deployments generate --mainnet && clarinet deployments apply",
    "console": "clarinet console",
    "check": "clarinet check",
    "format": "clarinet format"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@hirosystems/clarinet-sdk": "^3.7.0",
    "@stacks/transactions": "^7.0.6",
    "@types/node": "^22.15.18",
    "chokidar-cli": "^3.0.0"
  },
  "devDependencies": {
    "vitest": "^1.6.1"
  }
}
